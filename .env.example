# Shared local development values.
# Copy to .env for local shell usage. Do not commit real secrets.

# App
APP_ENV=development
APP_NAME=Vue API Workbench

# HTTP
BACKEND_ADDR=:8080
BACKEND_PUBLIC_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# SQLite is the local default. The path is relative to backend/ when running
# backend commands from that directory.
DATABASE_DRIVER=sqlite
DATABASE_URL=file:../my.local.db
DATABASE_AUTH_TOKEN=

# Passwords
PASSWORD_PEPPER=

# JWT
# Replace JWT secrets in any shared or production environment.
JWT_ACCESS_SECRET=dev-access-secret-at-least-32-bytes
JWT_REFRESH_SECRET=dev-refresh-secret-at-least-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Cookies
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false

# Bootstrap manager
# When enabled, backend seeds the first manager before starting the HTTP server.
BOOTSTRAP_MANAGER_ENABLED=false
BOOTSTRAP_MANAGER_EMAIL=
BOOTSTRAP_MANAGER_USERNAME=
BOOTSTRAP_MANAGER_PASSWORD=

# Frontend / Nuxt
NUXT_PUBLIC_APP_NAME=Vue API Workbench
# Private server runtime config. Nuxt maps this to runtimeConfig.apiBaseUrl.
NUXT_API_BASE_URL=http://localhost:8080

# Docker Compose
COMPOSE_PROJECT_NAME=vue-api
FRONTEND_PORT=3000
BACKEND_PORT=8080
SQLITE_DATA_PATH=./data/my.local.db
COMPOSE_DATABASE_URL=file:/data/my.local.db
COMPOSE_NUXT_API_BASE_URL=http://backend:8080
